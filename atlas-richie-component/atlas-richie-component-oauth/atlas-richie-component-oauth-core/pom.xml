<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.richie.component</groupId>
        <artifactId>atlas-richie-component-oauth</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>atlas-richie-component-oauth-core</artifactId>
    <packaging>jar</packaging>
    <name>atlas-richie-component-oauth-core</name>
    <description>OAuth2.1核心模块 - Token端点、客户端管理、Scope管理、公共模型与配置</description>

    <dependencies>
        <!-- 缓存组件（Redis操作） -->
        <dependency>
            <groupId>com.richie.component</groupId>
            <artifactId>atlas-richie-component-cache</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Spring Boot 自动装配 -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Jakarta Servlet API（过滤器场景） -->
        <dependency>
            <groupId>jakarta.servlet</groupId>
            <artifactId>jakarta.servlet-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- JWT（auth0） -->
        <dependency>
            <groupId>com.auth0</groupId>
            <artifactId>java-jwt</artifactId>
        </dependency>

        <!-- Apache Commons Lang3 -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-lang3</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <configuration>
                    <includes>
                        <include>com/richie/component/oauth/core/**</include>
                    </includes>
                    <excludes>
                        <exclude>com.richie.component.oauth.core.config.OAuth2RedisKey</exclude>
                        <exclude>com.richie.component.**.*AutoConfiguration</exclude>
                        <exclude>com.richie.component.**.config.**</exclude>
                        <exclude>com.richie.component.**.enums.**</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <id>jacoco-check</id>
                        <configuration combine.self="override">
                            <dataFile>${project.build.directory}/jacoco-merged.exec</dataFile>
                            <includes>
                                <include>com/richie/component/oauth/core/**</include>
                            </includes>
                            <excludes>
                                <exclude>com.richie.component.oauth.core.config.OAuth2RedisKey</exclude>
                                <exclude>com.richie.component.**.*AutoConfiguration</exclude>
                                <exclude>com.richie.component.**.config.**</exclude>
                                <exclude>com.richie.component.**.enums.**</exclude>
                            </excludes>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>${jacoco.coverage.minimum}</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
