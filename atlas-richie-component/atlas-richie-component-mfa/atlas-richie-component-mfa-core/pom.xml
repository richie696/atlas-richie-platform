<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.richie.component</groupId>
        <artifactId>atlas-richie-component-mfa</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>atlas-richie-component-mfa-core</artifactId>
    <packaging>jar</packaging>
    <name>atlas-richie-component-mfa-core</name>
    <description>MFA核心模块 - 公共实体、枚举、工具类、配置类</description>

    <dependencies>
        <!-- 跨服务共享契约：GatewayContract / TenantFilterConfig -->
        <dependency>
            <groupId>com.richie.base</groupId>
            <artifactId>atlas-richie-contract</artifactId>
        </dependency>
        <!-- 基础依赖 -->
        <dependency>
            <groupId>com.richie.component</groupId>
            <artifactId>atlas-richie-component-cache</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- MyBatis-Plus（用于实体类的 @TableName、@TableField 等注解） -->
        <dependency>
            <groupId>com.baomidou</groupId>
            <artifactId>mybatis-plus-annotation</artifactId>
        </dependency>

        <dependency>
            <groupId>com.baomidou</groupId>
            <artifactId>mybatis-plus-core</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Vault客户端（可选，如果使用Vault作为KMS） -->
        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-vault-config</artifactId>
            <optional>true</optional>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <configuration>
                    <includes>
                        <include>com/richie/component/mfa/core/util/**</include>
                        <include>com/richie/component/mfa/core/support/**</include>
                        <include>com/richie/component/mfa/core/crypto/provider/LocalKeyManagementEngine*</include>
                        <include>com/richie/component/mfa/core/crypto/hsm/DefaultHsmEngine*</include>
                        <include>com/richie/component/mfa/core/event/**</include>
                    </includes>
                </configuration>
                <executions>
                    <execution>
                        <id>jacoco-check</id>
                        <configuration combine.self="override">
                            <dataFile>${project.build.directory}/jacoco-merged.exec</dataFile>
                            <includes>
                                <include>com/richie/component/mfa/core/util/**</include>
                                <include>com/richie/component/mfa/core/support/**</include>
                                <include>com/richie/component/mfa/core/crypto/provider/LocalKeyManagementEngine*</include>
                                <include>com/richie/component/mfa/core/crypto/hsm/DefaultHsmEngine*</include>
                                <include>com/richie/component/mfa/core/event/**</include>
                            </includes>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>${jacoco.coverage.minimum}</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>
        </plugins>
    </build>

</project>
