<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.richie.component</groupId>
        <artifactId>atlas-richie-component-mfa</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>atlas-richie-component-mfa-management</artifactId>
    <packaging>jar</packaging>
    <name>atlas-richie-component-mfa-management</name>
    <description>MFA管理模块 - 部署在通用服务，操作数据库，使用Liquibase管理DDL</description>

    <dependencies>
        <!-- 数据库组件 -->
        <dependency>
            <groupId>com.richie.component</groupId>
            <artifactId>atlas-richie-component-dao</artifactId>
        </dependency>

        <!-- Liquibase组件 -->
        <dependency>
            <groupId>com.richie.component</groupId>
            <artifactId>atlas-richie-component-liquibase</artifactId>
        </dependency>

        <!-- 缓存组件（读写） -->
        <dependency>
            <groupId>com.richie.component</groupId>
            <artifactId>atlas-richie-component-cache</artifactId>
        </dependency>

        <!-- MFA核心模块（公共实体、枚举、工具类） -->
        <dependency>
            <groupId>com.richie.component</groupId>
            <artifactId>atlas-richie-component-mfa-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- 加密库 -->
        <dependency>
            <groupId>org.bouncycastle</groupId>
            <artifactId>bcprov-jdk18on</artifactId>
        </dependency>

        <!-- QR码生成 -->
        <dependency>
            <groupId>com.google.zxing</groupId>
            <artifactId>core</artifactId>
        </dependency>

        <dependency>
            <groupId>com.google.zxing</groupId>
            <artifactId>javase</artifactId>
        </dependency>

        <!-- Spring Boot Starter -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-crypto</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- MFA验证模块（用于TOTP验证） -->
        <dependency>
            <groupId>com.richie.component</groupId>
            <artifactId>atlas-richie-component-mfa-validation</artifactId>
        </dependency>

        <!-- Apache Commons Codec（用于 Base32 编码） -->
        <dependency>
            <groupId>commons-codec</groupId>
            <artifactId>commons-codec</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <configuration>
                    <includes>
                        <include>com/richie/component/mfa/management/manager/MfaCacheSyncManager*</include>
                        <include>com/richie/component/mfa/management/manager/SecretKeyManager*</include>
                        <include>com/richie/component/mfa/management/util/**</include>
                    </includes>
                </configuration>
                <executions>
                    <execution>
                        <id>jacoco-check</id>
                        <configuration combine.self="override">
                            <dataFile>${project.build.directory}/jacoco-merged.exec</dataFile>
                            <includes>
                                <include>com/richie/component/mfa/management/manager/MfaCacheSyncManager*</include>
                                <include>com/richie/component/mfa/management/manager/SecretKeyManager*</include>
                                <include>com/richie/component/mfa/management/util/**</include>
                            </includes>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.83</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>
        </plugins>
    </build>

</project>
