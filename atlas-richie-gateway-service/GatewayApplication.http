### 02.获取 access_token（Client Credentials）
< {%
    // 从全局变量获取 clientId 和 clientSecret（如果已通过注册接口设置）
    // 如果没有，使用下面硬编码的默认值（请先运行注册接口）
    let clientId = client.global.get("clientId") || 'client-20251224-450';
    let clientSecret = client.global.get("clientSecret") || 'Sv4ljDbG3tzQTLJsUZoTq6POD2RBrvbv';

    // 生成 Authorization header
    const authorization = `Basic ${btoa(clientId + ':' + clientSecret)}`;
    client.global.set("authorization", authorization);
    client.log("使用客户端凭据: clientId=" + clientId);
%}
POST http://localhost:9500/api/oauth2/token
Authorization: {{authorization}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

> {%
    // 定义工具函数（在当前响应处理脚本上下文中）
    function parseResponseBody(responseBody) {
        if (!responseBody) {
            return null;
        }
        if (typeof responseBody === 'string') {
            if (responseBody.trim() === '') {
                return null;
            }
            try {
                return JSON.parse(responseBody);
            } catch (e) {
                client.log("JSON 解析失败: " + e.message);
                return null;
            }
        } else if (typeof responseBody === 'object') {
            return responseBody;
        }
        return null;
    }

    function logErrorResponse(status, responseBody) {
        client.log("请求失败: status=" + status);
        if (responseBody) {
            try {
                const errorData = parseResponseBody(responseBody);
                client.log("错误详情: " + JSON.stringify(errorData || responseBody));
            } catch (e) {
                client.log("响应体: " + JSON.stringify(responseBody));
            }
        }
    }

    // 响应处理脚本：将 token 响应存储到全局变量

    if (response.status === 200) {
        try {
            const tokenData = parseResponseBody(response.body);

            // 响应格式：{"access_token": "...", "token_type": "Bearer", "expires_in": 3600, "refresh_token": "...", "scope": "..."}
            if (tokenData) {
                if (tokenData.access_token) {
                    client.global.set("accessToken", tokenData.access_token);
                    client.log("已保存 access_token 到全局变量");
                }
                if (tokenData.refresh_token) {
                    client.global.set("refreshToken", tokenData.refresh_token);
                    client.log("已保存 refresh_token 到全局变量");
                }
                if (tokenData.expires_in) {
                    client.global.set("tokenExpiresIn", tokenData.expires_in);
                    client.log("Token 有效期: " + tokenData.expires_in + " 秒");
                }
                if (tokenData.token_type) {
                    client.global.set("tokenType", tokenData.token_type);
                    client.log("Token 类型: " + tokenData.token_type);
                }
            }
        } catch (e) {
            client.log("处理响应失败: " + e.message);
            client.log("响应体类型: " + typeof response.body);
            client.log("响应体内容: " + JSON.stringify(response.body));
        }
    } else {
        logErrorResponse(response.status, response.body);
    }
%}

