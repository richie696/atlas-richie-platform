### 01.注册新的客户ID【仅测试】
POST http://127.0.0.1:9500/api/oauth2/test/client/register
Accept: application/json
Content-Type: application/json

{
  "client_name": "test-client"
}

> {%
    // 定义工具函数（在当前响应处理脚本上下文中）
    function parseResponseBody(responseBody) {
        if (!responseBody) {
            return null;
        }
        if (typeof responseBody === 'string') {
            if (responseBody.trim() === '') {
                return null;
            }
            try {
                return JSON.parse(responseBody);
            } catch (e) {
                client.log("JSON 解析失败: " + e.message);
                return null;
            }
        } else if (typeof responseBody === 'object') {
            return responseBody;
        }
        return null;
    }

    function logErrorResponse(status, responseBody) {
        client.log("请求失败: status=" + status);
        if (responseBody) {
            try {
                const errorData = parseResponseBody(responseBody);
                client.log("错误详情: " + JSON.stringify(errorData || responseBody));
            } catch (e) {
                client.log("响应体: " + JSON.stringify(responseBody));
            }
        }
    }

    // 响应处理脚本：自动将注册结果存储到全局变量

    if (response.status === 200) {
        try {
            const registerData = parseResponseBody(response.body);

            // 响应格式：{"client_id": "...", "client_secret": "..."}（直接返回 VO，未包装在 ResultVO 中）
            if (registerData) {
                const clientId = registerData.client_id || registerData.clientId;
                const clientSecret = registerData.client_secret || registerData.clientSecret;

                if (clientId && clientSecret) {
                    client.global.set("clientId", clientId);
                    client.global.set("clientSecret", clientSecret);
                    // 同时生成 Authorization header 并保存
                    const authorization = `Basic ${btoa(clientId + ':' + clientSecret)}`;
                    client.global.set("authorization", authorization);
                    client.log("已自动保存客户端凭据到全局变量: clientId=" + clientId);
                    client.log("现在可以直接运行'获取 access_token'请求，无需手动配置");
                } else {
                    client.log("注册接口响应格式错误，未找到 client_id 或 client_secret: " + JSON.stringify(registerData));
                }
            }
        } catch (e) {
            client.log("处理响应失败: " + e.message);
            client.log("响应体类型: " + typeof response.body);
            client.log("响应体内容: " + JSON.stringify(response.body));
        }
    } else {
        logErrorResponse(response.status, response.body);
    }
%}
