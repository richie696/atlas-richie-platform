### 03.刷新 access_token（Refresh Token）
POST http://localhost:9500/api/oauth2/token
Content-Type: application/x-www-form-urlencoded

grant_type=refresh_token&refresh_token={{refreshToken}}

> {%
    // 定义工具函数（在当前响应处理脚本上下文中）
    function parseResponseBody(responseBody) {
        if (!responseBody) {
            return null;
        }
        if (typeof responseBody === 'string') {
            if (responseBody.trim() === '') {
                return null;
            }
            try {
                return JSON.parse(responseBody);
            } catch (e) {
                client.log("JSON 解析失败: " + e.message);
                return null;
            }
        } else if (typeof responseBody === 'object') {
            return responseBody;
        }
        return null;
    }

    function logErrorResponse(status, responseBody) {
        client.log("请求失败: status=" + status);
        if (responseBody) {
            try {
                const errorData = parseResponseBody(responseBody);
                client.log("错误详情: " + JSON.stringify(errorData || responseBody));
            } catch (e) {
                client.log("响应体: " + JSON.stringify(responseBody));
            }
        }
    }

    // 响应处理脚本：更新 token 到全局变量

    if (response.status === 200) {
        try {
            const tokenData = parseResponseBody(response.body);

            if (tokenData) {
                if (tokenData.access_token) {
                    client.global.set("accessToken", tokenData.access_token);
                    client.log("已更新 access_token 到全局变量");
                }
                if (tokenData.refresh_token) {
                    client.global.set("refreshToken", tokenData.refresh_token);
                    client.log("已更新 refresh_token 到全局变量");
                }
            }
        } catch (e) {
            client.log("处理响应失败: " + e.message);
        }
    } else {
        logErrorResponse(response.status, response.body);
    }
%}

